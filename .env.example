# Neon Postgres (pooled connection string from Neon Dashboard → Connect)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Neon Auth URL — Neon Console → Auth → Configuration
# MUST look like: https://ep-xxx.neonauth.REGION.aws.neon.tech/neondb/auth
# Do NOT paste your postgresql:// connection string here.
NEON_AUTH_BASE_URL="https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth"

# Generate with: openssl rand -base64 32  (must be 32+ characters)
NEON_AUTH_COOKIE_SECRET="replace-with-a-secret-at-least-32-characters-long"

# App URL (used by Stripe redirects)
NEXT_PUBLIC_APP_URL="https://jbonsai.netlify.app"

# Phase 4 — meal planner (optional; mock plans work without it)
OPENAI_API_KEY=
# OPENAI_MEAL_PLAN_MODEL=gpt-4.1-mini
# On Netlify, sync OpenAI is OFF by default (avoids 504). Set to 1 to try AI.
# OPENAI_MEAL_PLAN_SYNC=1
# Abort AI when sync is enabled (ms). Default 4000.
# OPENAI_MEAL_PLAN_TIMEOUT_MS=4000

# Unsplash photo library (free)
# Access Key = Client-ID for search/photos. Add this to Netlify env too.
# Secret Key is only for OAuth user login — BonsAI does not need it for meal photos.
# https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=
# UNSPLASH_SECRET_KEY=

# Phase 2 — Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=
STRIPE_PRICE_FAMILY_MONTHLY=
