# Neon / Netlify Database connection (one of these is enough):
# - NETLIFY_DATABASE_URL — set by the Netlify Neon extension
# - NETLIFY_DB_URL — set by Netlify Database
# - DATABASE_URL — paste a pooled connection string from Neon
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Neon Auth (Managed Better Auth) — required for sign-in
# From Neon Console → your project → Auth → Configuration
NEON_AUTH_BASE_URL="https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth"

# Generate with: openssl rand -base64 32  (must be 32+ characters)
NEON_AUTH_COOKIE_SECRET="replace-with-a-secret-at-least-32-characters-long"
